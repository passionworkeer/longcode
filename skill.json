{
  "name": "longcode",
  "version": "1.0.0",
  "description": "长时间自主开发代理 - 从需求收集到代码部署的全流程自动化",
  "author": "Claude + User",
  "category": "automation",
  "tags": ["automation", "full-stack", "agent", "planning", "testing", "autonomous"],
  "parameters": [
    {
      "name": "--resume",
      "type": "flag",
      "description": "从上次中断处恢复执行"
    },
    {
      "name": "--status",
      "type": "flag",
      "description": "显示当前执行状态"
    },
    {
      "name": "--pause",
      "type": "flag",
      "description": "暂停执行"
    },
    {
      "name": "--max-tasks",
      "type": "number",
      "description": "限制执行的任务数量"
    }
  ],
  "files": [
    "prompt.md",
    "skill.md",
    "README.md"
  ],
  "dependencies": [
    "planner",
    "tdd-workflow",
    "security-review",
    "coding-standards",
    "frontend-patterns",
    "backend-patterns"
  ],
  "settings": {
    "max_task_duration": 120,
    "max_retries": 3,
    "enable_git": true,
    "git_branch_pattern": "feature/longcode-{timestamp}",
    "parallel_agents": "on-demand",
    "review_required": true,
    "security_scan": true,
    "auto_commit": true,
    "log_level": "balanced",
    "require_questions": 10,
    "never_ask_user_during_execution": true,
    "skip_on_failure_after_retries": true
  },
  "acceptance_criteria": {
    "required": [
      "code_compiles",
      "tests_pass",
      "no_high_security_issues",
      "code_review_passes"
    ],
    "optional": [
      "test_coverage_80_percent",
      "performance_metrics_met"
    ]
  }
}
