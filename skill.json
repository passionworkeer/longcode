{
  "name": "longcode",
  "version": "1.6.0",
  "description": "长时间自主开发代理 - 从需求收集到代码部署的全流程自动化",
  "author": "Claude + User",
  "category": "automation",
  "tags": ["automation", "full-stack", "agent", "planning", "testing", "autonomous"],
  "parameters": [
    {
      "name": "--resume",
      "type": "flag",
      "short": "-r",
      "description": "从上次中断处恢复执行"
    },
    {
      "name": "--status",
      "type": "flag",
      "short": "-s",
      "description": "显示当前执行状态"
    },
    {
      "name": "--pause",
      "type": "flag",
      "short": "-p",
      "description": "暂停执行"
    },
    {
      "name": "--max-tasks",
      "type": "number",
      "short": "-t",
      "description": "限制执行的任务数量"
    },
    {
      "name": "--dry-run",
      "type": "flag",
      "short": "-d",
      "description": "演示模式，只显示不执行"
    },
    {
      "name": "--verbose",
      "type": "flag",
      "short": "-v",
      "description": "显示详细日志"
    },
    {
      "name": "--quiet",
      "type": "flag",
      "short": "-q",
      "description": "只显示关键信息"
    },
    {
      "name": "--no-preview",
      "type": "flag",
      "description": "跳过预览直接执行"
    },
    {
      "name": "--no-cost",
      "type": "flag",
      "description": "隐藏成本估算"
    },
    {
      "name": "--cost-limit",
      "type": "number",
      "description": "成本熔断阈值 (默认 $5)"
    },
    {
      "name": "--checkpoint-every",
      "type": "number",
      "description": "每 N 个任务触发检查点 (默认 4)"
    }
  ],
  "files": [
    "prompt.md",
    "skill.md",
    "README.md",
    "OVERVIEW.md",
    "COMPETITIVE_ANALYSIS.md",
    "OPTIMIZATION.md",
    "CRITIQUE_RESPONSE.md",
    "agents/"
  ],
  "dependencies": {
    "note": "这些是可选的外部 skill，不存在时会使用内置逻辑",
    "optional": [
      "planner",
      "tdd-workflow",
      "security-review",
      "coding-standards",
      "frontend-patterns",
      "backend-patterns"
    ]
  },
  "settings": {
    "max_task_duration": 120,
    "max_retries": 3,
    "enable_git": true,
    "git_branch_pattern": "feature/longcode-{timestamp}",
    "parallel_agents": "on-demand",
    "review_required": true,
    "security_scan": true,
    "auto_commit": true,
    "log_level": "balanced",
    "require_questions": 10,
    "never_ask_user_during_execution": true,
    "skip_on_failure_after_retries": true,
    "show_progress_bar": true,
    "estimate_duration": true,
    "estimate_cost": true,
    "interactive_planning": true,
    "preview_before_execute": true,
    "demo_mode": false,
    "checkpoint_every": 4,
    "cost_limit": 5.0,
    "cost_conservative_multiplier": 3.0,
    "dependency_blocking": true,
    "smart_git_merge": true
  },
  "acceptance_criteria": {
    "required": [
      "code_compiles",
      "tests_pass",
      "no_high_security_issues",
      "code_review_passes"
    ],
    "optional": [
      "test_coverage_80_percent",
      "performance_metrics_met"
    ]
  },
  "time_estimates": {
    "ui_component": {"base": 30, "complexity_add": 15},
    "api_endpoint": {"base": 45, "complexity_add": 20},
    "database": {"base": 30, "complexity_add": 15},
    "testing": {"base": 25, "complexity_add": 10},
    "bug_fix": {"base": 20, "complexity_add": 15}
  },
  "cost_estimates": {
    "model": "claude-3.5-sonnet",
    "input_rate": 3.0,
    "output_rate": 15.0,
    "task_tokens": {
      "ui_component": {"min": 5000, "max": 15000},
      "api_endpoint": {"min": 8000, "max": 20000},
      "database": {"min": 5000, "max": 15000},
      "testing": {"min": 3000, "max": 10000},
      "bug_fix": {"min": 2000, "max": 8000}
    }
  }
}
